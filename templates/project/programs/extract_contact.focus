fork d1 provider model system input schema max_output_tokens
pack provider=provider model=model system=system input=input schema=schema max_output_tokens=max_output_tokens
call llm_json
out

branch provider
const "openai"
end

branch model
const "gpt-5-mini"
end

branch system
const "Extract a compact contact record from the text."
end

branch input
in raw_text
end

branch schema
in schema
end

branch max_output_tokens
const 220
end
